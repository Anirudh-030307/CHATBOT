{
  "name": "chatbot",
  "displayName": "chatbot",
  "description": "ai chatbot",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "chatbot.helloWorld",
        "title": "Hello World"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chat",
          "title": "Ai chat bot",
          "icon": "./pics/vs-code.svg"
        }
      ]
    },
    "views": {
      "chat": [
        {
          "type": "webview",
          "id": "chatView",
          "name": "Chat",
          "icon": "./pics/vscode.svg"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.4",
    "globals": "^17.6.0"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.30.0",
    "@xenova/transformers": "^2.17.2",
    "apache-arrow": "^21.1.0",
    "dotenv": "^17.4.2",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "web-tree-sitter": "^0.26.9"
  }
}
